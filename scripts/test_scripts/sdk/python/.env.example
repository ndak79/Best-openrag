# OpenRAG SaaS smoke-test configuration.
# Copy to .env and fill in your deployment's values.

# Base URL of the OpenRAG deployment (no trailing slash needed)
OPENRAG_URL=https://your-openrag-instance.example.com

# IBM SaaS credentials — sent as X-Username / X-Api-Key headers
OPENRAG_USERNAME=your-user@example.com
OPENRAG_API_KEY=your-api-key
